    <string name="privacy_title">Privacy policy</string>
    <string name="privacy_settings_summary">Data use, Android backup and permissions</string>
    <string name="privacy_intro_title">Private by design</string>
    <string name="privacy_intro_body">Your financial records are processed by WHFIN on this device. WHFIN currently has no account, analytics SDK or application server.</string>
    <string name="privacy_data_section">DATA HANDLING</string>
    <string name="privacy_financial_title">Financial records</string>
    <string name="privacy_financial_body">Accounts, transactions, categories and debts live in the app’s private local database.</string>
    <string name="privacy_backup_title">Encrypted Android backup</string>
    <string name="privacy_backup_body">If encrypted device backup is enabled, Android may back up the database and preferences. WHFIN cannot read that backup.</string>
    <string name="privacy_export_title">Portable JSON backup</string>
    <string name="privacy_export_body">Created only when you choose a destination. It is not encrypted and contains financial records, but excludes SMS, OTP codes, credentials, tokens, permissions, and Android Keystore keys.</string>
    <string name="privacy_app_lock_title">App Lock</string>
    <string name="privacy_app_lock_body">An optional WHFIN code and strong biometrics hide financial content and recent-app snapshots. The code is verified with a non-exportable Android Keystore key; it does not encrypt the Room database.</string>
    <string name="privacy_sms_title">Credo messages</string>
    <string name="privacy_sms_body">Optional. New transaction messages can become drafts. A separate action can check the last 90 days locally. Raw SMS and OTP codes are never stored by WHFIN, exported, or uploaded.</string>
    <string name="privacy_files_title">Files you choose</string>
    <string name="privacy_files_body">WHFIN reads a statement only after you select it with Android’s system file picker.</string>
    <string name="privacy_control_section">YOUR CONTROL</string>
    <string name="privacy_permissions_title">Android permissions</string>
    <string name="privacy_permissions_body">Review or revoke WHFIN’s access in system settings.</string>
    <string name="privacy_network_title">Bank sync is not active</string>
    <string name="privacy_network_body">A future Credo connection will require explicit consent and an updated privacy policy before any financial data leaves the device.</string>
