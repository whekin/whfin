#!/usr/bin/env bash
# Блокирует коммит, если публичные проверки приватности не проходят
# (реальные IBAN/карты, secrets, personal paths, финансовые артефакты).
# Подключение после клона: git config core.hooksPath .githooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"
exec ./scripts/check-public-tree.sh
